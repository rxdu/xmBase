# Backward-compatibility package config (ADR 0003).
#
# The foundation library was renamed xmSigma -> xmBase. This shim lets consumers
# that still call find_package(xmSigma) and link xmotion::xmSigma keep working by
# forwarding to the installed xmBase package (installed alongside, at ../xmBase)
# and re-exposing the target under its old name. Migrate to find_package(xmBase)
# + xmotion::xmBase when convenient.

include("${CMAKE_CURRENT_LIST_DIR}/../xmBase/xmBaseConfig.cmake")

if (TARGET xmotion::xmBase AND NOT TARGET xmotion::xmSigma)
  add_library(xmSigma_compat INTERFACE)
  target_link_libraries(xmSigma_compat INTERFACE xmotion::xmBase)
  add_library(xmotion::xmSigma ALIAS xmSigma_compat)
endif ()

set(xmSigma_FOUND TRUE)
